generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  SHOP
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ASSEMBLING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

model Shop {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int      @unique @map("user_id")
  address   String?
  latitude  Float?
  longitude Float?
  radius    Float    @default(500) // meters
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]
  orders    Order[]
  customers User[]    @relation("SelectedShop")

  @@map("shops")
}

model User {
  id             Int      @id @default(autoincrement())
  telegramId     BigInt   @unique @map("telegram_id")
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  username       String?
  role           Role     @default(CLIENT)
  address        String?
  selectedShopId Int?     @map("selected_shop_id")
  entrance       String?
  floor          String?
  apartment      String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  selectedShop Shop?  @relation("SelectedShop", fields: [selectedShopId], references: [id], onDelete: SetNull)
  orders       Order[]
  shop         Shop?

  @@map("users")
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  price     Float
  imageUrl  String?  @map("image_url")
  stock     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  shopId    Int?     @map("shop_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop       Shop?       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  shopId          Int?        @map("shop_id")
  status          OrderStatus @default(PENDING)
  totalAmount     Float       @map("total_amount")
  deliveryFee     Float       @default(200) @map("delivery_fee")
  deliveryAddress String      @map("delivery_address")
  entrance        String?
  floor           String?
  apartment       String?
  comment         String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  acceptedAt      DateTime?   @map("accepted_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop  Shop?       @relation(fields: [shopId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id              Int   @id @default(autoincrement())
  orderId         Int   @map("order_id")
  productId       Int   @map("product_id")
  quantity        Int
  priceAtPurchase Float @map("price_at_purchase")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
